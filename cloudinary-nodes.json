        "jsCode": "const d = $input.first().json;\nlet caption = d.caption;\nif (!caption) {\n  caption = [\n    `🚗 ${d.title}`,\n    `📋 ${d.subtitle}`,\n    ``,\n    `💰 Təxmini alış qiyməti: ${d.price}`,\n    ``,\n    `📞 Ətraflı məlumat üçün profilə müraciət edin.`,\n    ``,\n    d.hashtags,\n  ].join('\\n');\n}\nreturn [{ json: { ...d, caption } }];"
      },
      "id": "node-new-caption",
